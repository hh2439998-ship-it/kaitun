local function EquipWeapon(weaponName)
    local tool = Player.Backpack:FindFirstChild(weaponName)
    if tool then 
        Player.Character.Humanoid:EquipTool(tool) 
    end
end

local function AutoEquipTool()
    pcall(function()
        if Player.Character and not Player.Character:FindFirstChildOfClass("Tool") then
            for _, v in pairs(Player.Backpack:GetChildren()) do
                if v:IsA("Tool") and (v.ToolTip == "Melee" or v.ToolTip == "Sword") then
                    Player.Character.Humanoid:EquipTool(v)
                    break
                end
            end
        end
    end)
end
