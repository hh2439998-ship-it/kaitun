            if Boss and Boss.Humanoid.Health > 0 then topos(Boss.HumanoidRootPart.CFrame * CFrame.new(0, 20, 0)) else topos(CFrame.new(-2850, 48, -10750)) end
            _G.CurrentAction = "Đang farm Tide Keeper tìm Water Key" return "FightBoss"
        else 
            topos(CFrame.new(-3065, 240, -10143)) task.wait(0.5) CommF:InvokeServer("BuySharkmanKarate") return "BuyStyle" 
        end
    end

    if not HasItem("Dragon Talon") and game.PlaceId == 7449423635 and GetMastery("Dragon Breath") >= 400 then
        if not HasItem("Fire Essence") then
            if (Player.Data.Bones.Value or 0) >= 50 then
                topos(CFrame.new(-1650, 38, -60)) task.wait(0.5) CommF:InvokeServer("Bones", "Buy", 1) _G.CurrentAction = "Đang Gacha xương tìm Hỏa Tinh"
            else 
                _G.CurrentAction = "Đang cày Xương tại Lâu Đài Bóng Đêm để Gacha" return "FarmBones" 
            end
            return "FightBoss"
        else 
            topos(CFrame.new(-12463, 331, -7565)) task.wait(0.5) CommF:InvokeServer("BuyDragonTalon") return "BuyStyle" 
        end
    end

    if not HasItem("Godhuman") and game.PlaceId == 7449423635 and GetMastery("Death Step") >= 400 and GetMastery("Sharkman Karate") >= 400 and GetMastery("Electric Claw") >= 400 and GetMastery("Dragon Talon") >= 400 and GetMastery("Superhuman") >= 400 then
        _G.CurrentAction = "Đã đủ điều kiện! Đang di chuyển mua GODHUMAN"
        topos(CFrame.new(-2422, 10, -4221)) task.wait(0.5) CommF:InvokeServer("BuyGodhuman")
    end
    return "FarmNormal"
end
