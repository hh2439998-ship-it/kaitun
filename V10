function EquipWeapon(weaponName)
    local tool = Player.Backpack:FindFirstChild(weaponName)
    if tool then Player.Character.Humanoid:EquipTool(tool) end
end

function HasItem(itemName)
    return Player.Backpack:FindFirstChild(itemName) or (Player.Character and Player.Character:FindFirstChild(itemName))
end

function GetMastery(StyleName)
    local tool = Player.Backpack:FindFirstChild(StyleName) or Player.Character:FindFirstChild(StyleName)
    if tool and tool:FindFirstChild("Level") then return tool.Level.Value end
    return 0
end
