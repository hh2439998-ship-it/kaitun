-- [3. ENGINE TWEEN DI CHUYỂN HOÀN HẢO TÍCH HỢP CHỐNG RƠI]
function toTarget(TargetPos)
    local HRP = GetSafeRoot()
    if not HRP then return end
    
    local Distance = (HRP.Position - TargetPos.Position).Magnitude
    
    -- Nếu khoảng cách quá ngắn, lập tức đặt tọa độ trực tiếp để tối ưu thời gian
    if Distance < 18 then
        HRP.CFrame = TargetPos
        return
    end
    
    -- Cơ chế duy trì độ cao không cho nhân vật bị rơi tự do xuống vực sâu
    local AntiFallBV = HRP:FindFirstChild("HoangHub_VelocityFly")
    if not AntiFallBV then
        AntiFallBV = Instance.new("BodyVelocity")
        AntiFallBV.Name = "HoangHub_VelocityFly"
        AntiFallBV.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
        AntiFallBV.Velocity = Vector3.new(0, 0, 0)
        AntiFallBV.Parent = HRP
    end
    
    -- Thiết lập thông số và chạy Tween di chuyển
    local Speed = getgenv().TweenSpeed or 315
    local TimeRequired = Distance / Speed
    local CustomTweenInfo = TweenInfo.new(TimeRequired, Enum.EasingStyle.Linear)
    
    local ActiveTween = TweenService:Create(HRP, CustomTweenInfo, {CFrame = TargetPos})
    ActiveTween:Play()
    
    -- Luồng giám sát tắt/mở Script giữa chừng để hủy Tween kịp thời
    task.spawn(function()
        while ActiveTween.PlaybackState == Enum.PlaybackState.Playing do
            task.wait(0.1)
            if not getgenv().Kaitun_HoangHub then
                ActiveTween:Cancel()
                if HRP:FindFirstChild("HoangHub_VelocityFly") then
                    HRP.HoangHub_VelocityFly:Destroy()
                end
            end
        end
    end)
    
    ActiveTween.Completed:Wait()
    
    -- Thu dọn BodyVelocity sau khi đã tiếp cận mục tiêu hoàn tất
    if getgenv().TargetMonster == "" and HRP:FindFirstChild("HoangHub_VelocityFly") then
        HRP.HoangHub_VelocityFly:Destroy()
    end
end

-- [4. BỘ HỆ THỐNG PHÁT HIỆN VÀ GIẢI CỨU KHI BỊ KẸT (ANTI-STUCK DETECTOR)]
task.spawn(function()
    while task.wait(1) do
        if getgenv().Kaitun_HoangHub and getgenv().AutoFarm then
            pcall(function()
                local HRP = GetSafeRoot()
                if HRP then
                    local CurrentPos = HRP.Position
                    local DistanceMoved = (CurrentPos - LastPosition).Magnitude
                    
                    -- Nếu khoảng cách thay đổi dưới 2 studs trong khi đang bật farm quái
                    if DistanceMoved < 2 and getgenv().TargetMonster ~= "" then
                        StuckTime = StuckTime + 1
                    else
                        StuckTime = 0
                    end
                    
                    -- Tiến hành giải cứu nếu thời gian kẹt vượt quá 5 giây liên tục
                    if StuckTime >= 5 then
                        print("[HoangHub] Phát hiện kẹt! Đang thực thi giải cứu nhân vật...")
                        -- Ép nhân vật nhảy lên cao đột ngột để thoát khỏi góc kẹt địa hình
                        HRP.CFrame = HRP.CFrame * CFrame.new(0, 60, 0)
                        task.wait(0.5)
                        StuckTime = 0
                    end
                    
                    LastPosition = CurrentPos
                end
            end)
        end
    end
end)

