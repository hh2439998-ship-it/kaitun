task.spawn(function()
    while task.wait() do
        if getgenv().Kaitun_HoangHub and getgenv().AutoFarm then
            pcall(function()
                -- Tính toán lại mốc cấp độ hiện tại để gán thông số
                UpdateQuestData()
                
                if getgenv().UI_Status then
                    getgenv().UI_Status.Text = "Cấp độ hiện tại: " .. Player.Data.Level.Value
                end
                
                -- KIỂM TRA ĐIỀU KIỆN TRẠNG THÁI NHIỆM VỤ QUA BIẾN GỐC CỦA GAME CƠ BẢN
                local QuestUI = Player.PlayerGui:FindFirstChild("Main") and Player.PlayerGui.Main:FindFirstChild("Quest")
                local HasCorrectQuest = false
                
                if QuestUI and QuestUI.Visible then
                    for _, childLabel in pairs(QuestUI:GetDescendants()) do
                        if childLabel:IsA("TextLabel") and string.find(childLabel.Text, getgenv().TargetMonster) then
                            HasCorrectQuest = true
                            break
                        end
                    end
                end
                
                -- Xử lý tình huống chưa nhận đúng nhiệm vụ quy định
                if not HasCorrectQuest then
                    if getgenv().UI_Quest then getgenv().UI_Quest.Text = "Trạng thái: Di chuyển đi nhận NV " .. getgenv().TargetMonster end
                    
                    -- Nếu đang dính một nhiệm vụ rác hoặc sai tên, thực hiện lệnh huỷ ngay
                    if QuestUI and QuestUI.Visible then
                        CommF:InvokeServer("AbandonQuest")
                        task.wait(0.3)
                    end
                    
                    local HRP = Player.Character and Player.Character:FindFirstChild("HumanoidRootPart")
                    if HRP then
                        local distanceToNPC = (HRP.Position - getgenv().QuestNPC.Position).Magnitude
                        if distanceToNPC > 15 then
                            toTarget(getgenv().QuestNPC)
                        else
                            -- Thực hiện lệnh Remote Invoke chọc thẳng Server ép nhận nhiệm vụ
                            CommF:InvokeServer("StartQuest", getgenv().QuestName, getgenv().QuestLevel)
                            task.wait(0.5)
                        end
                    end
                else
                    -- Đã kiểm tra đúng nhiệm vụ trên Server -> Tiến hành farm quái
                    if getgenv().UI_Quest then getgenv().UI_Quest.Text = "Đang tiêu diệt: " .. getgenv().TargetMonster end
                    
                    local ActiveMob = FindAliveTargetMob()
                    if ActiveMob and ActiveMob:FindFirstChild("HumanoidRootPart") then
                        -- Bay lên đầu quái đúng 8 studs để giữ khoảng cách an toàn và tấn công dồn dập
                        local FightCFrame = ActiveMob.HumanoidRootPart.CFrame * CFrame.new(0, 8, 0)
                        toTarget(FightCFrame)
                    else
                        -- Nếu quái chưa hồi sinh, bay lơ lửng tại điểm chờ quái xuất hiện để tránh rơi xuống đất
                        toTarget(getgenv().MobPos * CFrame.new(0, 18, 0))
                    end
                end
            end)
        end
    end
end)

