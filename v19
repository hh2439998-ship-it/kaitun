-- [3. HÀM TÌM KIẾM QUÁI MỤC TIÊU CÒN SỐNG TRONG WORKSPACE]
local function FindAliveTargetMob()
    local OptimalMob = nil
    local MinimumDistance = math.huge
    local MyHRP = Player.Character and Player.Character:FindFirstChild("HumanoidRootPart")
    
    if MyHRP then
        for _, enemy in pairs(workspace.Enemies:GetChildren()) do
            if enemy.Name == getgenv().TargetMonster and enemy:FindFirstChild("Humanoid") and enemy.Humanoid.Health > 0 then
                local EnemyHRP = enemy:FindFirstChild("HumanoidRootPart")
                if EnemyHRP then
                    local currentMag = (MyHRP.Position - EnemyHRP.Position).Magnitude
                    if currentMag < MinimumDistance then
                        MinimumDistance = currentMag
                        OptimalMob = enemy
                    end
                end
            end
        end
    end
    return OptimalMob
end

