-- [3. ENGINE FIX LAG XI MĂNG TỐI THƯỢNG - XÓA SẠCH VẬT LIỆU MÔI TRƯỜNG]
local function ActivateSuperCement()
    print("[HoangHub] Đang thực thi Engine Xi Măng chuyên sâu...")
    
    -- Khóa cứng thông số ánh sáng môi trường để giảm tải CPU/GPU
    Lighting.GlobalShadows = false
    Lighting.FogEnd = 999999
    Lighting.Brightness = 1
    Lighting.ClockTime = 12
    Lighting.OutdoorAmbient = Color3.fromRGB(128, 128, 128)
    Lighting.Ambient = Color3.fromRGB(128, 128, 128)
    
    -- Quét và hủy toàn bộ hiệu ứng hình ảnh phức tạp trong phần Lighting
    for _, effect in pairs(Lighting:GetChildren()) do
        if effect:IsA("Sky") or effect:IsA("Atmosphere") or effect:IsA("BloomEffect") 
        or effect:IsA("BlurEffect") or effect:IsA("ColorCorrectionEffect") 
        or effect:IsA("SunRaysEffect") then
            effect:Destroy()
        end
    end
    
    -- Xử lý triệt để vật liệu của Địa hình (Terrain) - Đặc biệt là hiệu ứng sóng nước
    local Terrain = workspace:FindFirstChildOfClass("Terrain")
    if Terrain then
        Terrain.WaterWaveSize = 0
        Terrain.WaterWaveSpeed = 0
        Terrain.WaterReflectance = 0
        Terrain.WaterTransparency = 1
        Terrain.Decoration = false
        Terrain:SetMaterialColor(Enum.Material.Grass, Color3.fromRGB(130, 130, 130))
        Terrain:SetMaterialColor(Enum.Material.Water, Color3.fromRGB(130, 130, 130))
        Terrain:SetMaterialColor(Enum.Material.Rock, Color3.fromRGB(130, 130, 130))
        Terrain:SetMaterialColor(Enum.Material.Sand, Color3.fromRGB(130, 130, 130))
    end
    
    -- Hàm ép mọi BasePart và Mesh về dạng Xi Măng Xám Phẳng
    local function ApplyCementToPart(part)
        if part:IsA("BasePart") and not part:IsA("MeshPart") then
            part.Material = Enum.Material.SmoothPlastic
            part.Color = Color3.fromRGB(140, 140, 140)
            part.Reflectance = 0
            part.CastShadow = false
        elseif part:IsA("MeshPart") then
            part.Material = Enum.Material.SmoothPlastic
            part.Color = Color3.fromRGB(140, 140, 140)
            part.Reflectance = 0
            part.CastShadow = false
            part.TextureID = "" -- Xóa cấu trúc ảnh bề mặt của Mesh
        elseif part:IsA("Texture") or part:IsA("Decal") then
            part:Destroy()
        elseif part:IsA("ParticleEmitter") or part:IsA("Trail") 
        or part:IsA("Fire") or part:IsA("Smoke") or part:IsA("Sparkles") then
            part.Enabled = false
            part:Destroy()
        end
    end
    
    -- Chạy vòng lặp quét toàn bộ Workspace hiện tại
    for _, object in pairs(workspace:GetDescendants()) do
        pcall(function()
            ApplyCementToPart(object)
        end)
    end
    
    -- Tạo trình lắng nghe liên tục cho các vật thể mới được sinh ra trong tương lai
    workspace.DescendantAdded:Connect(function(newChild)
        pcall(function()
            ApplyCementToPart(newChild)
        end)
    end)
end

