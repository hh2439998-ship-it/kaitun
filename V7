                local TushitaDoorCFrame = CFrame.new(4622, 45, 2841)
                topos(TushitaDoorCFrame)
                return "GettingTushita"
            else
                -- Nếu có Tushita rồi, đánh indra
                return indra
            end
        end

        -- 2. Ưu tiên Dough King
        local doughKing = workspace.Enemies:FindFirstChild("Dough King")
        if doughKing and doughKing:FindFirstChild("Humanoid") and doughKing.Humanoid.Health > 0 then
            return doughKing
        end

        -- 3. Điều kiện Yama (Đã đủ 30 Elite Kills)
        local ElitesKilled = Player:FindFirstChild("Leaderstats") and Player.Leaderstats:FindFirstChild("Elite Kills") and Player.Leaderstats["Elite Kills"].Value or 0
        if ElitesKilled >= 30 and not HasItem("Yama") then
            local YamaCFrame = CFrame.new(-5255, 15, 5550) 
            if (GetHRP().Position - YamaCFrame.Position).Magnitude > 20 then
                topos(YamaCFrame)
            else
                local YamaModel = workspace:FindFirstChild("Map") and workspace.Map:FindFirstChild("HydraIsland") and workspace.Map.HydraIsland:FindFirstChild("SecretTemple") and workspace.Map.HydraIsland.SecretTemple:FindFirstChild("Yama")
                if YamaModel and YamaModel:FindFirstChild("ClickDetector") then fireclickdetector(YamaModel.ClickDetector) end
            end
            return "GettingYama"
        end

        -- 4. Săn Elite Hunter
        for _, enemy in pairs(workspace.Enemies:GetChildren()) do
            for _, eliteName in pairs(EliteBosses) do
                if enemy.Name == eliteName and enemy:FindFirstChild("Humanoid") and enemy.Humanoid.Health > 0 then
                    return enemy
                end
            end
        end
    end
    return nil
end

