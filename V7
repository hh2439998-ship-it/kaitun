-- PHẦN 2: Movement Khóa Vị Trí (Chống văng) & Fast Attack + Net Bypass

local function GetHRP()
    if Player.Character and Player.Character:FindFirstChild("HumanoidRootPart") then return Player.Character.HumanoidRootPart end
    return nil
end

local function HoldPosition(pos)
    local hrp = GetHRP()
    if hrp then
        if not hrp:FindFirstChild("HoldBV") then
            local bv = Instance.new("BodyVelocity")
            bv.Name = "HoldBV"
            bv.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
            bv.Velocity = Vector3.new(0, 0, 0)
            bv.Parent = hrp
        end
        hrp.CFrame = pos
    end
end

local function ClearHold()
    local hrp = GetHRP()
    if hrp and hrp:FindFirstChild("HoldBV") then hrp.HoldBV:Destroy() end
end

local function topos(TargetCFrame)
    local hrp = GetHRP()
    if not hrp then return end
    local distance = (hrp.Position - TargetCFrame.Position).Magnitude
    if distance < 10 then 
        HoldPosition(TargetCFrame)
        return 
    end
    ClearHold()
    local time = distance / getgenv().TweenSpeed
    local tweenInfo = TweenInfo.new(time, Enum.EasingStyle.Linear)
    local tween = TweenService:Create(hrp, tweenInfo, {CFrame = TargetCFrame})
    
    if not hrp:FindFirstChild("BodyClip") then
        local bv = Instance.new("BodyVelocity")
        bv.Name = "BodyClip"
        bv.MaxForce = Vector3.new(100000, 100000, 100000)
        bv.Velocity = Vector3.new(0, 0, 0)
        bv.Parent = hrp
    end
    
    for _, v in pairs(Player.Character:GetDescendants()) do
        if v:IsA("BasePart") then v.CanCollide = false end
    end
    
    tween:Play()
    tween.Completed:Wait()
    if hrp:FindFirstChild("BodyClip") then hrp.BodyClip:Destroy() end
    HoldPosition(TargetCFrame)
end

