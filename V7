local function CheckFailsafe(taskName)
    if getgenv().CurrentTask ~= taskName then
        getgenv().CurrentTask = taskName
        getgenv().FailsafeTimer = tick()
    end
    
    -- Nếu treo quá 420 giây (7 phút) ở cùng 1 mục tiêu
    if tick() - getgenv().FailsafeTimer > 420 then
        print("Phát hiện kẹt lỗi 7 phút! Đang khởi động lại lộ trình...")
        getgenv().CurrentTarget = nil
        getgenv().CurrentTask = ""
        getgenv().FailsafeTimer = tick()
        if Player.Character and Player.Character:FindFirstChild("Humanoid") then
            Player.Character.Humanoid.Health = 0 -- Tự sát để reset về đảo an toàn
        end
        task.wait(5)
        return true
    end
    return false
end

