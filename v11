-- THUẬT TOÁN DI CHUYỂN TWEEN CFRAME BYPASS KHÔNG BỊ KHÓA NHÂN VẬT VẬN HÀNH ỔN ĐỊNH
local function GetCharacterRoot()
    if Player.Character and Player.Character:FindFirstChild("HumanoidRootPart") then
        return Player.Character.HumanoidRootPart
    end
    return nil
end

function topos(TargetCFrame)
    local root = GetCharacterRoot()
    if not root then return end
    
    local distance = (root.Position - TargetCFrame.Position).Magnitude
    if distance < 18 then 
        root.CFrame = TargetCFrame
        return 
    end
    
    local speed = getgenv().TweenSpeed or 300
    local calculatedTime = distance / speed
    local tweenInfo = TweenInfo.new(calculatedTime, Enum.EasingStyle.Linear)
    
    -- Khởi tạo lực nâng chống rớt vực khi di chuyển qua các biển
    if not root:FindFirstChild("V7AntiFallVelocity") then
        local bodyVelocity = Instance.new("BodyVelocity")
        bodyVelocity.Name = "V7AntiFallVelocity"
        bodyVelocity.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
        bodyVelocity.Velocity = Vector3.new(0, 0, 0)
        bodyVelocity.Parent = root
    end
    
    -- Tắt va chạm tạm thời để không bị kẹt tường, kẹt núi lửa
    for _, part in pairs(Player.Character:GetDescendants()) do
        if part:IsA("BasePart") then 
            part.CanCollide = false 
        end
    end
    
    local tween = TweenService:Create(root, tweenInfo, {CFrame = TargetCFrame})
    tween:Play()
    tween.Completed:Wait()
    
    if root:FindFirstChild("V7AntiFallVelocity") then 
        root.V7AntiFallVelocity:Destroy() 
    end
    root.CFrame = TargetCFrame
      end
