            Terrain.WaterReflectance = 0
            Terrain.WaterTransparency = 1
            Terrain.Decoration = false
            Terrain:SetMaterialColor(Enum.Material.Grass, Color3.fromRGB(120, 120, 120))
            Terrain:SetMaterialColor(Enum.Material.Water, Color3.fromRGB(120, 120, 120))
            Terrain:SetMaterialColor(Enum.Material.Sand, Color3.fromRGB(120, 120, 120))
            Terrain:SetMaterialColor(Enum.Material.Rock, Color3.fromRGB(120, 120, 120))
            Terrain:SetMaterialColor(Enum.Material.Mud, Color3.fromRGB(120, 120, 120))
        end
    end)
end

-- THUẬT TOÁN BIẾN MỌI VẬT THỂ THÀNH XI MĂNG (LẬP TRÌNH ĐA LUỒNG TRÁNH LAG)
local function TurnPartIntoCement(instance)
    pcall(function()
        if instance:IsA("BasePart") and not instance:IsA("MeshPart") then
            instance.Material = Enum.Material.SmoothPlastic
            instance.Color = Color3.fromRGB(115, 115, 115)
            instance.Reflectance = 0
            instance.CastShadow = false
        elseif instance:IsA("MeshPart") then
            instance.Material = Enum.Material.SmoothPlastic
            instance.Color = Color3.fromRGB(115, 115, 115)
            instance.Reflectance = 0
            instance.CastShadow = false
            instance.TextureID = ""
        elseif instance:IsA("Decal") or instance:IsA("Texture") or instance:IsA("SurfaceAppearance") then
            instance:Destroy()
        elseif instance:IsA("ParticleEmitter") or instance:IsA("Trail") or instance:IsA("Fire") or instance:IsA("Smoke") or instance:IsA("Sparkles") then
            instance.Enabled = false
        end
    end)
end

-- TIẾN HÀNH QUÉT TOÀN BỘ BẢN ĐỒ LẦN ĐẦU
local function ApplySuperCementToWorld()
    pcall(function()
        local descendants = Workspace:GetDescendants()
        local count = 0
        for i = 1, #descendants do
            TurnPartIntoCement(descendants[i])
            count = count + 1
            -- Nghỉ một nhịp sau mỗi 500 vật thể để chống đứng máy khi Load script
            if count % 500 == 0 then
                task.wait()
            end
        end
    end)
end

