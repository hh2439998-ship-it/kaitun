function EquipWeapon()
    for _, v in pairs(Player.Backpack:GetChildren()) do
        if v:IsA("Tool") and (v.ToolTip == "Melee" or v.ToolTip == "Sword") then 
            Player.Character.Humanoid:EquipTool(v) 
        end
    end
end

