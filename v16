-- [1. TRUNG TÂM QUẢN LÝ MUA CÁC VÕ MELEE V1 - TẬN NƠI TRÁNH LỖI MUA TỪ XA]
local MeleeV1Table = {
    {Name = "Black Leg", Cost = 150000, Remote = "BuyBlackLeg", NPC_CFrame = CFrame.new(-1246.06, 4.74, 3914.38), PlaceId = 2753915549},
    {Name = "Electro", Cost = 500000, Remote = "BuyElectro", NPC_CFrame = CFrame.new(-4625.68, 849.27, -2534.66), PlaceId = 2753915549},
    {Name = "Fishman Kung Fu", Cost = 750000, Remote = "BuyFishmanKungFu", NPC_CFrame = CFrame.new(6112.59, 18.49, 1565.34), PlaceId = 2753915549}
}

local function AutoBuyMeleeV1Engine()
    local currentBeli = Player.Data.Beli.Value
    local currentMelee = Player.Character:FindFirstChildOfClass("Tool") and Player.Character:FindFirstChildOfClass("Tool").Name or ""
    
    for _, melee in pairs(MeleeV1Table) do
        if game.PlaceId == melee.PlaceId and currentBeli >= melee.Cost then
            local hasWeapon = Player.Backpack:FindFirstChild(melee.Name) or Player.Character:FindFirstChild(melee.Name)
            if not hasWeapon and currentMelee ~= melee.Name then
                if getgenv().GlobalMeleeStatus then
                    getgenv().GlobalMeleeStatus.Text = "Đang di chuyển mua võ: " .. melee.Name
                end
                -- Bay sát tận nơi tọa độ NPC dạy võ để hệ thống game xác nhận vị trí hợp lệ
                topos(melee.NPC_CFrame)
                task.wait(0.6)
                CommF:InvokeServer(melee.Remote)
                task.wait(0.6)
                return true
            end
        end
    end
    if getgenv().GlobalMeleeStatus then
        getgenv().GlobalMeleeStatus.Text = "Trạng thái Võ: Tối ưu kinh tế thành công!"
    end
    return false
end

