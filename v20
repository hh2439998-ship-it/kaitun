local Player = Players.LocalPlayer
local CommF = ReplicatedStorage:WaitForChild("Remotes"):WaitForChild("CommF_")
local Workspace = game:GetService("Workspace")

function UpdateQuestData()
    local MyLvl = Player.Data.Level.Value
    for _, db in pairs(getgenv().RedzQuestDatabase) do
        if MyLvl >= db.MinLevel and MyLvl <= db.MaxLevel then
            getgenv().TargetMonster = db.TargetName
            getgenv().QuestName = db.QuestId
            getgenv().QuestLevel = db.QuestLevel
            getgenv().QuestNPC = db.NPCPosition
            getgenv().MobPos = db.MobPosition
            break
        end
    end
end

-- [HÀM TÌM QUÁI TỐI ƯU NHẤT]
local function FindAliveTargetMob()
    local BestMob = nil
    local MinDist = math.huge
    local HRP = Player.Character and Player.Character:FindFirstChild("HumanoidRootPart")
    
    if HRP then
        for _, mob in pairs(Workspace.Enemies:GetChildren()) do
            if mob.Name == getgenv().TargetMonster and mob:FindFirstChild("Humanoid") and mob.Humanoid.Health > 0 then
                local MobHRP = mob:FindFirstChild("HumanoidRootPart")
                if MobHRP then
                    local dist = (HRP.Position - MobHRP.Position).Magnitude
                    if dist < MinDist then
                        MinDist = dist
                        BestMob = mob
                    end
                end
            end
        end
    end
    return BestMob
end

-- [VÒNG LẶP AUTO FARM ĐỈNH CAO XUYÊN LỖI UI]
task.spawn(function()
    while task.wait() do
        if getgenv().Kaitun_HoangHub and getgenv().AutoFarm then
            pcall(function()
                UpdateQuestData()
                
                if getgenv().UI_Status then
                    getgenv().UI_Status.Text = "Cấp độ hiện tại: " .. Player.Data.Level.Value
                end
                
                local QuestUI = Player.PlayerGui:FindFirstChild("Main") and Player.PlayerGui.Main:FindFirstChild("Quest")
                local CheckQuest = false
                
                if QuestUI and QuestUI.Visible then
                    for _, label in pairs(QuestUI:GetDescendants()) do
                        if label:IsA("TextLabel") and string.find(label.Text, getgenv().TargetMonster) then
                            CheckQuest = true
                            break
                        end
                    end
                end
                
                if not CheckQuest then
                    if getgenv().UI_Quest then getgenv().UI_Quest.Text = "Đang đi nhận: " .. getgenv().TargetMonster end
                    
                    if QuestUI and QuestUI.Visible then
                        CommF:InvokeServer("AbandonQuest")
                        task.wait(0.3)
                    end
                    
                    local HRP = Player.Character and Player.Character:FindFirstChild("HumanoidRootPart")
                    if HRP then
                        if (HRP.Position - getgenv().QuestNPC.Position).Magnitude > 15 then
                            toTarget(getgenv().QuestNPC)
                        else
                            CommF:InvokeServer("StartQuest", getgenv().QuestName, getgenv().QuestLevel)
                            task.wait(0.5)
                        end
                    end
                else
                    if getgenv().UI_Quest then getgenv().UI_Quest.Text = "Đang chém: " .. getgenv().TargetMonster end
                    
                    local AliveMob = FindAliveTargetMob()
                    if AliveMob and AliveMob:FindFirstChild("HumanoidRootPart") then
                        toTarget(AliveMob.HumanoidRootPart.CFrame * CFrame.new(0, 8, 0))
                    else
                        toTarget(getgenv().MobPos * CFrame.new(0, 20, 0))
                    end
                end
            end)
        end
    end
end)

