-- [3. ENGINE SUPER CEMENT V9 & FPS BOOSTER (TỐI ĐA HÓA RAM)]
local function ActivateSuperCementAndBoostFPS()
    print("[HoangHub] Kích hoạt Super Cement & FPS Booster...")
    
    Lighting.GlobalShadows = false
    Lighting.FogEnd = 9e9
    Lighting.Brightness = 1
    Lighting.ClockTime = 12
    Lighting.OutdoorAmbient = Color3.fromRGB(150, 150, 150)
    Lighting.Ambient = Color3.fromRGB(150, 150, 150)
    
    -- Xóa mọi hiệu ứng ánh sáng nặng
    for _, effect in pairs(Lighting:GetChildren()) do
        if effect:IsA("Sky") or effect:IsA("Atmosphere") or effect:IsA("BloomEffect") 
        or effect:IsA("BlurEffect") or effect:IsA("ColorCorrectionEffect") or effect:IsA("SunRaysEffect") then
            effect:Destroy()
        end
    end
    
    -- Phẳng hóa địa hình, tắt sóng nước
    local Terrain = Workspace:FindFirstChildOfClass("Terrain")
    if Terrain then
        Terrain.WaterWaveSize = 0
        Terrain.WaterWaveSpeed = 0
        Terrain.WaterReflectance = 0
        Terrain.WaterTransparency = 1
        Terrain.Decoration = false
        Terrain:SetMaterialColor(Enum.Material.Grass, Color3.fromRGB(140, 140, 140))
        Terrain:SetMaterialColor(Enum.Material.Water, Color3.fromRGB(140, 140, 140))
        Terrain:SetMaterialColor(Enum.Material.Rock, Color3.fromRGB(140, 140, 140))
        Terrain:SetMaterialColor(Enum.Material.Sand, Color3.fromRGB(140, 140, 140))
    end
    
    -- Xóa tài nguyên vật thể
    local function OptimizeInstance(instance)
        if instance:IsA("BasePart") and not instance:IsA("MeshPart") then
            instance.Material = Enum.Material.SmoothPlastic
            instance.Color = Color3.fromRGB(140, 140, 140)
            instance.Reflectance = 0
            instance.CastShadow = false
        elseif instance:IsA("MeshPart") then
            instance.Material = Enum.Material.SmoothPlastic
            instance.Color = Color3.fromRGB(140, 140, 140)
            instance.Reflectance = 0
            instance.CastShadow = false
            instance.TextureID = ""
        elseif instance:IsA("Decal") or instance:IsA("Texture") then
            instance:Destroy()
        elseif instance:IsA("ParticleEmitter") or instance:IsA("Trail") or instance:IsA("Fire") or instance:IsA("Smoke") or instance:IsA("Sparkles") then
            instance.Enabled = false
            instance:Destroy()
        end
    end
    
    for _, obj in pairs(Workspace:GetDescendants()) do
        pcall(function() OptimizeInstance(obj) end)
    end
    
    Workspace.DescendantAdded:Connect(function(child)
        pcall(function() OptimizeInstance(child) end)
    end)
end
task.spawn(ActivateSuperCementAndBoostFPS)

