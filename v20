-- [2. HỆ THỐNG DI CHUYỂN TWEEN HOÀN HẢO]
function toTarget(TargetCFrame)
    local HRP = GetSafeHRP()
    if not HRP then return end
    
    local Distance = (HRP.Position - TargetCFrame.Position).Magnitude
    
    if Distance < 20 then
        HRP.CFrame = TargetCFrame
        return
    end
    
    local AntiFall = HRP:FindFirstChild("Hoang_AntiFall")
    if not AntiFall then
        AntiFall = Instance.new("BodyVelocity")
        AntiFall.Name = "Hoang_AntiFall"
        AntiFall.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
        AntiFall.Velocity = Vector3.new(0, 0, 0)
        AntiFall.Parent = HRP
    end
    
    local Speed = getgenv().TweenSpeed or 315
    local TimeNeeded = Distance / Speed
    local TInfo = TweenInfo.new(TimeNeeded, Enum.EasingStyle.Linear)
    
    local TweenRun = TweenService:Create(HRP, TInfo, {CFrame = TargetCFrame})
    TweenRun:Play()
    
    task.spawn(function()
        while TweenRun.PlaybackState == Enum.PlaybackState.Playing do
            task.wait(0.1)
            if not getgenv().Kaitun_HoangHub then
                TweenRun:Cancel()
                if HRP:FindFirstChild("Hoang_AntiFall") then
                    HRP.Hoang_AntiFall:Destroy()
                end
            end
        end
    end)
    
    TweenRun.Completed:Wait()
    
    if getgenv().TargetMonster == "" and HRP:FindFirstChild("Hoang_AntiFall") then
        HRP.Hoang_AntiFall:Destroy()
    end
end

-- [3. HỆ THỐNG CHỐNG KẸT ĐỊA HÌNH (ANTI-STUCK)]
task.spawn(function()
    while task.wait(1) do
        if getgenv().Kaitun_HoangHub and getgenv().AutoFarm then
            pcall(function()
                local HRP = GetSafeHRP()
                if HRP then
                    local CurrentPos = HRP.Position
                    local DistMoved = (CurrentPos - LastPos).Magnitude
                    
                    if DistMoved < 2 and getgenv().TargetMonster ~= "" then
                        StuckTick = StuckTick + 1
                    else
                        StuckTick = 0
                    end
                    
                    if StuckTick >= 6 then
                        print("[HoangHub] Giải cứu nhân vật khỏi góc kẹt...")
                        HRP.CFrame = HRP.CFrame * CFrame.new(0, 70, 0)
                        task.wait(0.5)
                        StuckTick = 0
                    end
                    LastPos = CurrentPos
                end
            end)
        end
    end
end)

