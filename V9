                            StartBring = true
                            topos(mob.HumanoidRootPart.CFrame * CFrame.new(0, 22, 0))
                            return
                        end
                    end
                    topos(CFrame.new(-9482, 142, 5567)) return
                elseif StyleStatus == "FightBoss" or StyleStatus == "BuyStyle" then
                    StartBring = false
                    return
                end

                -- Bước 3: Auto Farm Chuẩn
                local qData = GetQuestData(Player.Data.Level.Value)
                local QuestUI = Player.PlayerGui.Main.Quest
                
                if not QuestUI.Visible then
                    StartBring = false
                    _G.CurrentAction = "Nhận Quest: " .. qData.QuestName .. " (" .. qData.MobName .. ")"
                    if (GetHRP().Position - qData.QuestPos.Position).Magnitude > 15 then
                        topos(qData.QuestPos)
                    else
                        CommF:InvokeServer("StartQuest", qData.QuestName, qData.QuestID)
                    end
                else
                    _G.CurrentAction = "Đang Cày: " .. qData.MobName
                    local targetMob = nil
                    for _, mob in pairs(Workspace.Enemies:GetChildren()) do
                        if mob.Name == qData.MobName and mob:FindFirstChild("Humanoid") and mob.Humanoid.Health > 0 then
                            targetMob = mob
                            break
                        end
                    end

                    if targetMob then
                        PosMon = targetMob.HumanoidRootPart.CFrame
                        MonFarm = targetMob.Name
                        StartBring = true
                        EquipWeapon(Player.Character:FindFirstChildOfClass("Tool") and Player.Character:FindFirstChildOfClass("Tool").Name or "Melee")
                        topos(targetMob.HumanoidRootPart.CFrame * CFrame.new(0, 22, 0))
                    else
                        StartBring = false
                        topos(qData.MobPos)
                    end
                end
            end)
        end
    end
end)

