                        return 
                    end
                end

                -- 2. Ưu tiên thực thi hệ thống võ thuật Godhuman nếu bật cấu hình
                if getgenv().AutoGodHuman and AutoGodHumanLogic() then 
                    -- Đang trong trạng thái cày mastery của võ chỉ định, chuyển đổi farm nhiệm vụ thường dưới dạng võ này
                end

                -- 3. Tiến hành phân tích chọn mục tiêu (Boss + Quái thường)
                SelectTarget(Player.Data.Value or Player.Data.Level.Value)
                if ManageFailsafe("Farming_" .. Mon) then return end 

                local QuestUI = Player.PlayerGui.Main.Quest
                local QuestTitle = QuestUI.Container.QuestTitle.Title.Text
                
                if not QuestUI.Visible or not string.find(QuestTitle, NameMon) then
                    if QuestUI.Visible then CommF:InvokeServer("AbandonQuest") task.wait(0.3) end
                    StartBring = false
                    getgenv().CurrentTarget = nil
