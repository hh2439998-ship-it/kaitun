                local WorldBoss = CheckSea3WorldEvents()
                if WorldBoss then
                    if ManageFailsafe("WorldEvent_" .. tostring(WorldBoss)) then return end
                    if typeof(WorldBoss) == "Instance" and WorldBoss:IsA("Model") then
                        getgenv().CurrentTarget = WorldBoss
                        PosMon = WorldBoss.HumanoidRootPart.CFrame
                        StartBring = true
                        MonFarm = WorldBoss.Name
                        topos(WorldBoss.HumanoidRootPart.CFrame * CFrame.new(0, 25, 0))
