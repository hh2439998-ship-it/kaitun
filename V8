-- THUẬT TOÁN KIỂM TRA LỖI KẸT 7 PHÚT (ANTI-STUCK ENGINE)
-- =========================================
local LastTargetHealth = nil
local LastHealthCheckTime = tick()

local function ManageFailsafe(taskName)
    if getgenv().CurrentTask ~= taskName then
        getgenv().CurrentTask = taskName
        getgenv().TaskStartTime = tick()
        LastHealthCheckTime = tick()
        LastTargetHealth = nil
    end
    
    local timeElapsed = tick() - getgenv().TaskStartTime
    LevelText.Text = "Level: " .. Player.Data.Level.Value .. " (FS: " .. math.floor(timeElapsed) .. "s)"

    -- Kiểm tra nếu có mục tiêu, xem máu có tụt không
    if getgenv().CurrentTarget and getgenv().CurrentTarget:FindFirstChild("Humanoid") then
        local currentHealth = getgenv().CurrentTarget.Humanoid.Health
        if LastTargetHealth and currentHealth < LastTargetHealth then
            LastHealthCheckTime = tick() -- Máu có giảm -> Vẫn đang farm tốt -> Làm tươi thời gian check máu
        end
        LastTargetHealth = currentHealth
    end

    -- Nếu đứng im tại một task quá 7 phút (420s) HOẶC máu quái không đổi suốt 7 phút
    if timeElapsed > 420 or (tick() - LastHealthCheckTime > 420) then
        print("PHÁT HIỆN LỖI HỆ THỐNG HOẶC QUÁI BỊ LỖI KẸT VỊ TRÍ! TIẾN HÀNH RESET CHARACTER LÀM MỚI LỘ TRÌNH...")
        getgenv().CurrentTarget = nil
        getgenv().CurrentTask = ""
        getgenv().TaskStartTime = tick()
        LastHealthCheckTime = tick()
        if Player.Character and Player.Character:FindFirstChild("Humanoid") then
            Player.Character.Humanoid.Health = 0 
        end
        task.wait(5)
        return true
    end
    return false
end

