local function AutoEquipWeapon()
    local weaponName = (getgenv().AutoGodHuman and not HasItem("Godhuman")) and getgenv().GodhumanWeapon or nil
    for _, tool in pairs(Player.Backpack:GetChildren()) do
        if tool:IsA("Tool") then
            if weaponName and tool.Name == weaponName then 
                Player.Character.Humanoid:EquipTool(tool)
                break
            elseif not weaponName and (tool.ToolTip == "Melee" or tool.ToolTip == "Sword") then 
                Player.Character.Humanoid:EquipTool(tool)
                break
            end
        end
    end
end

