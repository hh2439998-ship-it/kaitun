-- HÀM TRẢ VỀ DỮ LIỆU BÃI FARM THEO CẤP ĐỘ HIỆN TẠI TỰ ĐỘNG
function GetCurrentFarmData()
    local currentLevel = LocalPlayer.Data.Level.Value
    for i = 1, #getgenv().Sea1FarmData do
        local data = getgenv().Sea1FarmData[i]
        if currentLevel >= data.LevelMin and currentLevel < data.LevelMax then
            return data
        end
    end
    -- Mặc định trả về bãi cuối cùng nếu cấp độ vượt ngưỡng Sea 1
    return getgenv().Sea1FarmData[#getgenv().Sea1FarmData]
end

