-- LOGIC TỰ ĐỘNG CHỌN PHE HẢI TẶC (KẾ THỪA VÀ TỐI ƯU TỪ REDZ HUB V7)
local function AutoSelectPiratesTeam()
    local joinTeamRemote = ReplicatedStorage:WaitForChild("Remotes"):WaitForChild("CommF_")
    local success, _ = pcall(function()
        if LocalPlayer.Team == nil or LocalPlayer.Team.Name == "Choosing" then
            task.wait(0.5)
            joinTeamRemote:InvokeServer("SetTeam", "Pirates")
        end
    end)
    if not success then
        -- Phương pháp dự phòng nếu Remote chính bị chặn (Virtual Input)
        pcall(function()
            local mainUI = LocalPlayer.PlayerGui:WaitForChild("Main")
            local chooseTeamFrame = mainUI:WaitForChild("ChooseTeam")
            if chooseTeamFrame.Visible then
                local pirateButton = chooseTeamFrame:WaitForChild("Container"):WaitForChild("Pirates"):WaitForChild("Frame"):WaitForChild("ViewportFrame"):WaitForChild("TextButton")
                for _, connection in pairs(getconnections(pirateButton.MouseButton1Click)) do
                    connection:Fire()
                end
            end
        end)
    end
end

-- THỰC THI CHỌN PHE LẬP TỨC
task.spawn(function()
    while LocalPlayer.Team == nil or LocalPlayer.Team.Name == "Choosing" do
        AutoSelectPiratesTeam()
        task.wait(1)
    end
end)

