-- LOGIC AUTO CHỌN PHE HẢI TẶC (PIRATES) CỰC MƯỢT CỦA V7 - KHÔNG BAO GIỜ LỖI
local function ForceSelectPiratesTeam()
    local commF = ReplicatedStorage:WaitForChild("Remotes"):WaitForChild("CommF_")
    
    -- Bước 1: Gửi lệnh gọi Server trực tiếp để gán phe nhanh
    pcall(function()
        if LocalPlayer.Team == nil or LocalPlayer.Team.Name == "Choosing" then
            commF:InvokeServer("SetTeam", "Pirates")
        end
    end)
    
    -- Bước 2: Giả lập nhấp chuột nếu Server phản hồi chậm (An toàn tuyệt đối)
    pcall(function()
        local mainGui = LocalPlayer.PlayerGui:FindFirstChild("Main")
        if mainGui then
            local chooseTeam = mainGui:FindFirstChild("ChooseTeam")
            if chooseTeam and chooseTeam.Visible then
                local container = chooseTeam:FindFirstChild("Container")
                if container then
                    local piratesFrame = container:FindFirstChild("Pirates")
                    if piratesFrame then
                        local frame = piratesFrame:FindFirstChild("Frame")
                        if frame then
                            local viewport = frame:FindFirstChild("ViewportFrame")
                            if viewport then
                                local textButton = viewport:FindFirstChildOfClass("TextButton")
                                if textButton then
                                    for _, conn in pairs(getconnections(textButton.MouseButton1Click)) do
                                        conn:Fire()
                                    end
                                end
                            end
                        end
                    end
                end
            end
        end
    end)
end

