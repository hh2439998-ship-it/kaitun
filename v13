-- HÀM THƯ VIỆN LẤY DỮ LIỆU KHU VỰC THEO CẤP ĐỘ HIỆN TẠI
function SafeGetLevelFarmData()
    local currentLevel = 1
    pcall(function()
        currentLevel = LocalPlayer.Data.Level.Value
    end)
    
    for i = 1, #getgenv().Sea1MasterDatabase do
        local data = getgenv().Sea1MasterDatabase[i]
        if currentLevel >= data.LevelMin and currentLevel < data.LevelMax then
            return data
        end
    end
    -- Trả về bãi quái cuối cùng nếu người chơi vượt cấp Sea 1 sang Sea 2
    return getgenv().Sea1MasterDatabase[#getgenv().Sea1MasterDatabase]
end

