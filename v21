function EquipWeapon()
    for _, v in pairs(Player.Backpack:GetChildren()) do
        if v:IsA("Tool") and (v.ToolTip == "Melee" or v.ToolTip == "Sword") then 
            Player.Character.Humanoid:EquipTool(v) 
        end
    end
end

-- [VÒNG LẶP CHÍNH GỐC - ĐÃ GIỮ LẠI TOÀN BỘ LOGIC 8 STUDS VÀ TASK.WAIT(0.8) FIX LỖI UI]
task.spawn(function()
    while task.wait() do
        if getgenv().Kaitun then
            pcall(function()
                if Player.Data.Level.Value >= 2800 then return end
                if AutoBuyMeleeV1Engine() then return end

                local WorldBoss = CheckSea3WorldEvents()
                if WorldBoss then
                    if CheckFailsafe("WorldEvent_" .. tostring(WorldBoss)) then return end
                    if typeof(WorldBoss) == "Instance" and WorldBoss:IsA("Model") then
                        getgenv().CurrentTarget = WorldBoss
                        getgenv().PosMon = WorldBoss.HumanoidRootPart.CFrame
                        getgenv().StartBring = true
                        getgenv().MonFarm = WorldBoss.Name
                        topos(WorldBoss.HumanoidRootPart.CFrame * CFrame.new(0, 8, 0))
                        local tool = Player.Character:FindFirstChildOfClass("Tool")
                        if tool then tool:Activate() end
                        return
                    elseif WorldBoss == "GettingTushita" or WorldBoss == "GettingYama" then
                        return
                    end
                end

                if AutoSaber() then 
                    if CheckFailsafe("SaberExpert") then return end
                    return 
                end

                CheckQuest()
                if CheckFailsafe("Farming_" .. Mon) then return end 

                local QuestUI = Player.PlayerGui.Main.Quest
                local QuestTitle = QuestUI.Container.QuestTitle.Title.Text
                
                if not QuestUI.Visible or not string.find(QuestTitle, NameMon) then
                    if QuestUI.Visible then 
                        CommF:InvokeServer("AbandonQuest") 
                        task.wait(0.5) 
                    end
                    getgenv().StartBring = false
                    getgenv().CurrentTarget = nil
                    local HRP = Player.Character and Player.Character:FindFirstChild("HumanoidRootPart")
                    if HRP and (HRP.Position - CFrameQuest.Position).Magnitude > 20 then 
                        topos(CFrameQuest) 
                    else 
                        CommF:InvokeServer("StartQuest", NameQuest, LevelQuest) 
                        task.wait(0.8) 
                    end
                else
                    local Target = getgenv().CurrentTarget
                    if Target and Target.Parent and Target:FindFirstChild("Humanoid") and Target.Humanoid.Health > 0 and Target:FindFirstChild("HumanoidRootPart") then
                        if Player.Character and not Player.Character:FindFirstChild("HasBuso") then 
                            CommF:InvokeServer("Buso") 
                        end
                        EquipWeapon()
                        getgenv().PosMon = Target.HumanoidRootPart.CFrame
                        getgenv().StartBring = true
                        getgenv().MonFarm = Target.Name
                        topos(Target.HumanoidRootPart.CFrame * CFrame.new(0, 8, 0))
                        local tool = Player.Character:FindFirstChildOfClass("Tool")
                        if tool then tool:Activate() end
                    else
                        getgenv().CurrentTarget = nil
                        getgenv().StartBring = false
                        for _, mob in pairs(workspace.Enemies:GetChildren()) do
                            if mob.Name == Mon and mob:FindFirstChild("Humanoid") and mob:FindFirstChild("HumanoidRootPart") and mob.Humanoid.Health > 0 then
                                getgenv().CurrentTarget = mob
                                break
                            end
                        end
                        local HRP = Player.Character and Player.Character:FindFirstChild("HumanoidRootPart")
                        if not getgenv().CurrentTarget and HRP then 
                            topos(CFrameMon * CFrame.new(0, 8, 0)) 
                        end
                    end
                end
            end)
