local function GetMastery(StyleName)
    local tool = Player.Backpack:FindFirstChild(StyleName) or Player.Character:FindFirstChild(StyleName)
    if tool and tool:FindFirstChild("Level") then
        return tool.Level.Value
    end
    return 0
end

local function HasStyle(StyleName)
    return Player.Backpack:FindFirstChild(StyleName) or Player.Character:FindFirstChild(StyleName)
end

local function SelectRaidFruit()
    local bestFruit = nil
    for _, item in pairs(Player.Backpack:GetChildren()) do
        if item:IsA("Tool") and string.find(item.Name, "Fruit") then
            local price = item:GetAttribute("Price") or 0
            if price < 1000000 then 
                bestFruit = item
                break
            end
        end
    end
    return bestFruit
end

local GodHumanStep = 1
local function GodHumanLogic()
    local beli = Player.Data.Beli.Value
    local frags = Player.Data.Fragments.Value
    local level = Player.Data.Level.Value

    -- Bước 1: Mua Vô Hắc Cước V1 (Black Leg) khi đủ 150k Beli
    if GodHumanStep == 1 then
        if not HasStyle("Black Leg") then
            if beli >= 150000 then
                CommF:InvokeServer("BuyBlackLeg")
            end
        else
            if GetMastery("Black Leg") >= 300 then
                GodHumanStep = 2
            end
        end
    end

    -- Bước 2: Electro V1 - 500,000 Beli (Cày lên 300 Mas)
    if GodHumanStep == 2 then
        if not HasStyle("Electro") then
            if beli >= 500000 then
                CommF:InvokeServer("BuyElectro")
            end
        else
            if GetMastery("Electro") >= 300 then
                GodHumanStep = 3
            end
        end
    end

    -- Bước 3: Võ Người Cá V1 (Fishman Karate) - 750,000 Beli (Cày lên 300 Mas)
    if GodHumanStep == 3 then
        if not HasStyle("Fishman Karate") then
            if beli >= 750000 then
                CommF:InvokeServer("BuyFishmanKarate")
            end
        else
            if GetMastery("Fishman Karate") >= 300 then
                GodHumanStep = 4
            end
        end
    end

    -- ĐẶC BIỆT: Tự động đánh hai Boss đầu lâu và Lâu đài mùa đông tại Sea 2 kể cả khi chưa đủ cấp
    if level >= 700 and (game.PlaceId == 4442272183 or game.PlaceId == 79091703265657) then
        if not Player.Backpack:FindFirstChild("Hidden Key") and not Player.Character:FindFirstChild("Library Key") then
            local IceBoss = workspace.Enemies:FindFirstChild("Awakened Ice Admiral") or workspace.Enemies:FindFirstChild("Tide Keeper")
            if IceBoss and IceBoss:FindFirstChild("Humanoid") and IceBoss.Humanoid.Health > 0 then
                getgenv().CurrentTarget = IceBoss
                PosMon = IceBoss.HumanoidRootPart.CFrame
                StartBring = true
                MonFarm = IceBoss.Name
                topos(IceBoss.HumanoidRootPart.CFrame * CFrame.new(0, 25, 0))
                
                local tool = Player.Character:FindFirstChildOfClass("Tool")
                if tool then tool:Activate() end
                return true 
            end
        end
    end

    -- Bước 4: Mua võ Cổ Rồng V1 (Dragon Breath) & Tự động đi Raid kiếm Fragment
    if GodHumanStep == 4 then
        if not HasStyle("Dragon Breath") then
            if frags < 1500 then
                if level >= 1100 then
                    local raidFruit = SelectRaidFruit()
                    if raidFruit then
                        CommF:InvokeServer("RaidsNpc", "Select", "Flame")
                        task.wait(0.5)
                        CommF:InvokeServer("RaidsNpc", "Buy", raidFruit.Name)
                        task.wait(0.5)
                        fireclickdetector(workspace.Map.CircleIsland.RaidSummon2.Button.Main.ClickDetector)
                    end
                end
            else
                CommF:InvokeServer("BlackbeardReward", "DragonBreath", "1")
            end
        else
            if GetMastery("Dragon Breath") >= 300 then
                GodHumanStep = 5
            end
        end
    end

    -- Bước 5: Lên Super Human cày full Mastery và các võ V2 lên 400 Mas để lấy God Human
    if GodHumanStep == 5 then
        if not HasStyle("Superhuman") then
            if beli >= 3000000 then
                CommF:InvokeServer("BuySuperhuman")
            end
        else
            if GetMastery("Superhuman") >= 400 then
                GodHumanStep = 6
            end
        end
    end
    return false
end

